# ========================================
# ARQUIVO DE CONFIGURAÇÃO DE AMBIENTE
# ========================================
# Copie este arquivo para .env e ajuste os valores

# SEGURANÇA
# =========
# Gere uma chave secreta forte aqui: https://randomkeygen.com/
# Use pelo menos 32 caracteres
SECRET_KEY=gere-uma-chave-super-segura-aqui-com-mais-de-32-caracteres

# AMBIENTE
# ========
# Valores: development, production, testing
FLASK_ENV=development

# DEBUG MODE
# ==========
# NUNCA use True em produção!
FLASK_DEBUG=True

# BANCO DE DADOS
# ==============
# Se DATABASE_URL não for definida, cai para SQLite local (apenas dev).
# Em produção (Render), DATABASE_URL é injetada automaticamente ao conectar
# um banco Postgres gerenciado ao serviço web. Aceita tanto o prefixo
# postgres:// quanto postgresql:// (a app normaliza automaticamente).
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# UPLOADS (fotos de pacientes)
# =============================
# Caminho onde as fotos são salvas. Em produção no Render, deve apontar para
# o disco persistente anexado ao serviço (ver render.yaml), já que o
# filesystem padrão do Render é efêmero.
# UPLOAD_FOLDER=/var/data/uploads_clinica

# SERVIDOR
# ========
# HOST=0.0.0.0
# PORT=5000
